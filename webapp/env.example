# Database URL (Get from Neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth Configuration
# For production, Vercel automatically sets NEXTAUTH_URL
NEXTAUTH_SECRET="your-super-strong-secret"

# Google OAuth Credentials (GCP Console)
GOOGLE_CLIENT_ID="your-client-id"
GOOGLE_CLIENT_SECRET="your-client-secret"

# AI Configuration
AI_PROVIDER="deepseek" # options: openai, anthropic, gemini, deepseek
DEEPSEEK_API_KEY="your-api-key"
OPENAI_API_KEY="your-api-key"
ANTHROPIC_API_KEY="your-api-key"
GEMINI_API_KEY="your-api-key"
